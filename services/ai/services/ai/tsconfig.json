{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "outDir":           "./dist",
    "rootDir":          "./",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "noUnusedLocals":   true,
    "noImplicitReturns": true
  },
  "include": ["controller/**/*", "providers/**/*", "prompts/**/*", "utils/**/*", "app.ts"],
  "exclude": ["node_modules", "dist"]
}